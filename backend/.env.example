# ────────────────────────────────────────────────────────────
# Astra — Autonomous Global Accounting Agent
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────

# App
APP_NAME=Astra
DEBUG=false
SECRET_KEY=generate-a-strong-random-key-here

# ────────────────────────────────────────────────────────────
# Database (Neon PostgreSQL)
# ────────────────────────────────────────────────────────────
# 1. Sign up at https://neon.tech (free tier: 0.5 GB storage)
# 2. Create a project (e.g., "astra")
# 3. Copy the connection string from your Neon dashboard
# 4. Replace "postgresql://" with "postgresql+asyncpg://"
# 5. Paste below:
#
# Example:
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-cool-name-123456.us-east-2.aws.neon.tech/astra?sslmode=require
#
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxxx.us-east-2.aws.neon.tech/astra?sslmode=require

# ────────────────────────────────────────────────────────────
# AI (Anthropic Claude)
# ────────────────────────────────────────────────────────────
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ────────────────────────────────────────────────────────────
# Banking — Bank Feed Integrations
# ────────────────────────────────────────────────────────────
# Plaid (US/Canada) — https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Basiq (AU/NZ) — https://dashboard.basiq.io
BASIQ_API_KEY=

# TrueLayer (UK/EU) — https://console.truelayer.com
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=http://localhost:3000/callback/truelayer

# ────────────────────────────────────────────────────────────
# Email (Mailgun)
# ────────────────────────────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ────────────────────────────────────────────────────────────
# Payments (Stripe)
# ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ────────────────────────────────────────────────────────────
# Auth
# ────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ────────────────────────────────────────────────────────────
# CORS (comma-separated origins)
# ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001

# ────────────────────────────────────────────────────────────
# Rate Limiting
# ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
